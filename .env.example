# ============================================================
# Copy to .env and fill in your values (never commit .env)
#
# TOPOLOGY (local profile):
#   Laptop  (10.100.102.12): Ollama embedding + PostgreSQL pgvector
#   Desktop (runs the app) : Ollama chat model + Spring Boot app
# ============================================================

# -- Active profile ----------------------------------------
SPRING_PROFILES_ACTIVE=local

# -- LOCAL profile (split Ollama topology) -----------------
# Laptop Ollama — embedding model only
OLLAMA_EMBED_BASE_URL=http://10.100.102.12:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# Desktop Ollama — chat model only (localhost from Desktop)
OLLAMA_CHAT_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2:3b

# PostgreSQL on Laptop
PGVECTOR_URL=jdbc:postgresql://10.100.102.12:5432/ragdb
PGVECTOR_USER=rag_app
PGVECTOR_PASSWORD=rag_app_password

# -- WORK profile (Azure OpenAI + pgvector) ----------------
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_KEY=<your-key>
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o

# -- Shared RAG tuning -------------------------------------
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=80
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.75
RAG_COLLECTION=rag-poc-chunks
SERVER_PORT=8080
